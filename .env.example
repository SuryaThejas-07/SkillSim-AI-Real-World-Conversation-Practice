# API Provider Configuration
# Supports OpenAI-compatible providers: Groq, OpenAI, Together.ai, etc.
# IMPORTANT: Never commit your actual API keys to version control

# ============================================
# RECOMMENDED: Groq (Free, Fast, Reliable)
# ============================================
# 1. Get FREE API key from: https://console.groq.com/keys
# 2. Copy the key and paste it in .env.local
# 3. Supports 500+ requests/minute for free

VITE_OPENAI_API_KEY=gsk_your-groq-key-here
VITE_OPENAI_API_BASE=https://api.groq.com/openai/v1
VITE_OPENAI_MODEL=llama-3.3-70b-versatile

# ============================================
# ALTERNATIVE: OpenAI
# ============================================
# Cost: Pay-as-you-go (very cheap)
# Get key from: https://platform.openai.com/account/api-keys
# Models: gpt-4o-mini (recommended), gpt-4-turbo

# VITE_OPENAI_API_KEY=sk-proj-your-openai-key
# VITE_OPENAI_API_BASE=https://api.openai.com/v1
# VITE_OPENAI_MODEL=gpt-4o-mini

# ============================================
# ALTERNATIVE: Together.ai
# ============================================
# Get key from: https://api.together.xyz
# Models: llama-2, mistral, etc.

# VITE_OPENAI_API_KEY=your-together-key
# VITE_OPENAI_API_BASE=https://api.together.xyz/v1
# VITE_OPENAI_MODEL=meta-llama/Meta-Llama-3-8B-Instruct-Turbo